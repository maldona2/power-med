PORT=5001
NODE_ENV=development
DATABASE_URL=postgres://user:password@localhost:5433/mydb
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# JWT secret (use a strong random string in production)
JWT_SECRET=your-jwt-secret

# Super-admin (created by db:seed)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=YourPassword123!

# SendGrid — transactional email
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM=noreply@example.com

RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM="YourApp <noreply@example.com>"

# Google Calendar OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/calendar/callback

# 32-byte hex key for AES-256-GCM token encryption (generate with: openssl rand -hex 32)
GOOGLE_TOKEN_ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Google Calendar sync configuration (optional, defaults shown)
# GOOGLE_SYNC_MAX_RETRIES=5
# GOOGLE_SYNC_INITIAL_BACKOFF_MS=1000
# GOOGLE_SYNC_BATCH_SIZE=10
# GOOGLE_SYNC_WORKER_INTERVAL_MS=5000
# GOOGLE_RATE_LIMIT_RPS=10
# GOOGLE_RATE_LIMIT_RPM=600
# GOOGLE_SYNC_ALERT_THRESHOLD=0.05

# Mercado Pago credentials
MERCADO_PAGO_WEBHOOK_SECRET=your-mercado-pago-webhook-secret
MERCADO_PAGO_ACCESS_TOKEN=your-mercado-pago-access-token
MERCADO_PAGO_PUBLIC_KEY=your-mercado-pago-public-key
WEBHOOK_CALLBACK_URL=https://your-domain.com/api/subscriptions/webhooks
SUBSCRIPTION_REDIRECT_URL=https://your-domain.com/app/profile

OPENAI_API_KEY=your-openai-api-key

# AWS S3 - Session Photos
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=your-bucket-name
